# ============================================================
# Continue.dev Configuration — Generated by Ansible
# Place at: ~/.continue/config.yaml on each developer machine
#
# This config maximizes Cursor-like experience:
#   - Fast tab autocomplete
#   - Inline edit (Cmd+I)
#   - Chat with full codebase context (@codebase)
#   - Agent mode for multi-file edits
#   - Custom slash commands (/review, /test, /fix)
# ============================================================

name: "ML Cluster (Local)"

# --- Chat Models ---
models:
{% for model in litellm_models %}
{% if model.model_name != 'health-check' %}
  - title: "{{ model.description }}"
    provider: openai
    model: {{ model.model_name }}
    apiBase: "http://{{ gateway_ip }}:{{ litellm_port }}/v1"
    apiKey: "{{ litellm_api_key }}"
    completionOptions:
      temperature: {{ model.temperature | default(0.2) }}
{% if model.top_p is defined %}
      topP: {{ model.top_p }}
{% endif %}
      maxTokens: {{ model.max_tokens | default(4096) }}
      stream: true
{% if model.model_name == 'code-main' %}
    systemMessage: |
      You are a precise coding assistant running on a local ML cluster.
      Rules:
      - Only suggest code using libraries and APIs you are confident exist.
      - If unsure, say so explicitly — never invent imports or package names.
      - Reference the provided code context. Do not guess file structure.
      - When editing code, output ONLY the changed code with clear markers.
      - For multi-file changes, clearly label each file path.
{% endif %}

{% endif %}
{% endfor %}

# --- Tab Autocomplete (Cursor-like ghost text) ---
tabAutocompleteModel:
  title: "Autocomplete"
  provider: openai
  model: code-autocomplete
  apiBase: "http://{{ gateway_ip }}:{{ litellm_port }}/v1"
  apiKey: "{{ litellm_api_key }}"
  completionOptions:
    temperature: 0.05
    topP: 0.85
    maxTokens: 128
    stop: ["\n\n", "\nclass ", "\ndef ", "\nfunction ", "\n#", "\n//"]
    stream: true

tabAutocompleteOptions:
  useCopyBuffer: true              # Use clipboard content as context
  maxPromptTokens: 1500            # More context = better completions
  debounceDelay: 300               # 300ms — fast, like Cursor
  multilineCompletions: "always"   # Multi-line ghost text
  useOtherFiles: true              # Include other open files
  maxSuffixPercentage: 0.3         # 30% context for code after cursor
  onlyMyCode: true                 # Skip node_modules, vendor, etc.
  disableInFiles:
    - "*.md"
    - "*.json"
    - "*.yaml"
    - "*.yml"
    - "*.env"
    - "*.lock"
    - "*.min.js"
    - "*.min.css"

# --- Context Providers (powers @-mentions like Cursor) ---
contextProviders:
  # @codebase — search entire project (like Cursor's codebase chat)
  - name: codebase
    params:
      nRetrieve: 25                # Retrieve more chunks
      nFinal: 8                    # Include top 8 in prompt
      useReranking: true

  # @file — reference specific files
  - name: file
    params: {}

  # @folder — reference entire folders
  - name: folder
    params: {}

  # @code — reference specific code symbols
  - name: code
    params: {}

  # @open — all currently open editor tabs
  - name: open
    params:
      onlyPinned: false

  # @diff — current git changes (like Cursor's diff context)
  - name: diff
    params: {}

  # @terminal — recent terminal output (for error fixing)
  - name: terminal
    params: {}

  # @search — grep across project
  - name: search
    params: {}

  # @git — recent commits and branch info
  - name: git
    params:
      diff: "HEAD~5"

  # @url — fetch and include web page content
  - name: url
    params: {}

  # @tree — project file tree
  - name: tree
    params: {}

  # @problems — VS Code diagnostics (errors, warnings)
  - name: problems
    params: {}

# --- Embeddings (for @codebase RAG search) ---
embeddingsProvider:
  provider: ollama
  model: "nomic-embed-text"
  apiBase: "http://{{ gateway_ip }}:{{ ollama_port }}"

# --- Reranker (improves codebase search accuracy) ---
reranker:
  name: free-trial

# --- Slash Commands ---
slashCommands:
  - name: edit
    description: "Edit selected code inline"
  - name: comment
    description: "Add comments to code"
  - name: share
    description: "Share this conversation"
  - name: commit
    description: "Generate a commit message"

# --- Custom Slash Commands (Cursor-like) ---
customCommands:
  # /fix — Like Cursor's "Fix this error"
  - name: fix
    description: "Fix the bug or error in selected code"
    prompt: |
      Fix the bug in this code. Analyze the error carefully.
      - Show only the corrected code
      - Explain what was wrong in one sentence
      - If you need more context, ask

  # /review — Code review
  - name: review
    description: "Review code for bugs, security, and quality"
    prompt: |
      Review this code for:
      1. Bugs and logical errors
      2. Security vulnerabilities
      3. Performance issues
      4. Edge cases not handled
      Be specific. Reference line numbers. Only flag real issues.

  # /test — Generate tests
  - name: test
    description: "Generate comprehensive tests"
    prompt: |
      Generate unit tests for this code.
      - Use the project's existing test framework
      - Cover: happy path, edge cases, error handling
      - Make tests independent and deterministic
      - Don't over-mock — prefer real objects where practical

  # /explain — Explain code
  - name: explain
    description: "Explain what this code does"
    prompt: |
      Explain this code clearly and concisely.
      Focus on intent and logic, not syntax.
      Call out any non-obvious patterns or potential issues.

  # /refactor — Suggest improvements
  - name: refactor
    description: "Suggest refactoring improvements"
    prompt: |
      Suggest how to refactor this code for better readability and maintainability.
      - Keep the same behavior
      - Prefer simple, idiomatic solutions
      - Show the refactored version

  # /doc — Generate documentation
  - name: doc
    description: "Generate documentation/docstrings"
    prompt: |
      Add clear, concise documentation to this code.
      - Use the project's existing doc style
      - Document parameters, return values, and side effects
      - Skip obvious things

  # /optimize — Performance optimization
  - name: optimize
    description: "Optimize for performance"
    prompt: |
      Analyze this code for performance issues.
      Only suggest optimizations that are measurably impactful.
      Focus on algorithmic improvements and I/O, not micro-optimizations.

# --- Prompt Templates (improve 7B model output quality) ---
promptTemplates:
  edit: |
    Rewrite the code below based on this instruction: {{{ input }}}

    ```
    {{{ code }}}
    ```

    Output ONLY the rewritten code, no explanations. Keep the same language and style.

# --- UI Config ---
ui:
  codeBlockToolbar: true
  fontSize: 14
  displayRawMarkdown: false
