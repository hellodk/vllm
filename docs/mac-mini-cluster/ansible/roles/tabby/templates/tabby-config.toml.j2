# ============================================================
# Tabby Configuration — Generated by Ansible
# Self-hosted AI coding assistant
# ============================================================

# --- Completion Model ---
[model.completion.local]
# StarCoder2-3B is optimized for code completion on Apple Silicon
model_id = "StarCoder2-3B"

# --- Chat Model ---
[model.chat.local]
# Qwen2.5-Coder-7B for chat (same model as Ollama, but Tabby-managed)
model_id = "Qwen2.5-Coder-7B-Instruct"

# --- Repository Indexing ---
# Tabby indexes your repos for context-aware completions
# Add your team's repos here
{% for repo in tabby_repositories | default([]) %}
[[repositories]]
name = "{{ repo.name }}"
git_url = "{{ repo.git_url }}"
{% endfor %}

# --- Server ---
[server]
host = "0.0.0.0"
port = {{ tabby_port }}
