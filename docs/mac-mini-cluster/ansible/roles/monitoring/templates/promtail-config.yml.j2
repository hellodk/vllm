# Generated by Ansible — do not edit manually
server:
  http_listen_port: {{ promtail_port }}
  grpc_listen_port: 0

positions:
  filename: /tmp/positions.yaml

clients:
  - url: http://{{ gateway_ip }}:{{ loki_port }}/loki/api/v1/push
    batchwait: 1s
    batchsize: 1048576
    timeout: 10s

scrape_configs:
  - job_name: ollama
    static_configs:
      - targets: [localhost]
        labels:
          job: ollama
          node: "{{ inventory_hostname }}"
          __path__: /tmp/host-logs/ollama.log
    pipeline_stages:
      - regex:
          expression: '(?P<timestamp>\d{4}/\d{2}/\d{2} \d{2}:\d{2}:\d{2}) (?P<level>\w+) (?P<message>.*)'
      - labels:
          level:

  - job_name: ollama-errors
    static_configs:
      - targets: [localhost]
        labels:
          job: ollama-errors
          node: "{{ inventory_hostname }}"
          __path__: /tmp/host-logs/ollama-error.log

{% if node_role | default('inference') == 'gateway' %}
  - job_name: litellm
    static_configs:
      - targets: [localhost]
        labels:
          job: litellm
          node: "{{ inventory_hostname }}"
          __path__: /tmp/host-logs/litellm.log
    pipeline_stages:
      - multiline:
          firstline: '^\d{4}-\d{2}-\d{2}'
          max_wait_time: 3s
      - regex:
          expression: '(?P<timestamp>\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2},\d{3}) - (?P<level>\w+) - (?P<message>.*)'
      - labels:
          level:
{% endif %}
