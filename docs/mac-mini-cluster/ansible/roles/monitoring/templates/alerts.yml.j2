# Generated by Ansible — Hydra Pilot alert rules
groups:
  - name: hydra_inference
    interval: 30s
    rules:
      - alert: InferenceNodeDown
        expr: up{job=~"vllm-.*"} == 0
        for: 30s
        labels:
          severity: critical
        annotations:
          summary: "vLLM-MLX node {{ '{{' }} $labels.node {{ '}}' }} is down"

      - alert: KVCacheNearFull
        expr: vllm_mlx_kv_cache_usage_percent > 85
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "KV cache usage >85% on {{ '{{' }} $labels.node {{ '}}' }}"

      - alert: HighTTFT
        expr: histogram_quantile(0.95, rate(vllm_mlx_time_to_first_token_seconds_bucket[5m])) > 5
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "P95 TTFT exceeds 5s"

      - alert: HighErrorRate
        expr: rate(vllm_mlx_requests_total{status="error"}[5m]) / rate(vllm_mlx_requests_total[5m]) > 0.1
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "Error rate exceeds 10%"

  - name: hydra_gateway
    interval: 30s
    rules:
      - alert: GatewayDown
        expr: up{job="litellm"} == 0
        for: 1m
        labels:
          severity: critical
        annotations:
          summary: "LiteLLM gateway is unreachable"

      - alert: RateLimitSpike
        expr: rate(litellm_rate_limit_hits_total[5m]) > 1
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "Sustained rate limit hits — users may need higher limits"

  - name: hydra_resources
    interval: 30s
    rules:
      - alert: MemoryPressure
        expr: (1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) > 0.90
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "Memory >90% on {{ '{{' }} $labels.node {{ '}}' }}"
