# Generated by Ansible — Hydra Pilot
global:
  scrape_interval: 15s
  evaluation_interval: 15s
  scrape_timeout: 10s

rule_files:
  - "alerts.yml"

scrape_configs:
  - job_name: "prometheus"
    static_configs:
      - targets: ["localhost:9090"]

  # LiteLLM Gateway metrics
  - job_name: "litellm"
    metrics_path: /metrics
    scrape_interval: 10s
    static_configs:
      - targets: ["host.docker.internal:{{ litellm_port }}"]
        labels:
          service: "litellm-proxy"

  # vLLM-MLX inference nodes (replaces Ollama)
{% for host in groups['inference'] %}
  - job_name: "vllm-{{ host }}"
    metrics_path: /metrics
    scrape_interval: 15s
    static_configs:
      - targets: ["{{ hostvars[host]['ansible_host'] }}:{{ vllm_port }}"]
        labels:
          node: "{{ host }}"
          chip: "{{ hostvars[host]['node_chip'] }}"
          ram: "{{ hostvars[host]['node_ram_gb'] }}gb"
          runtime: "vllm-mlx"
{% endfor %}

  # System metrics (node_exporter) — all nodes
{% for group_name in ['gateway', 'inference'] %}
{% for host in groups[group_name] %}
  - job_name: "node-{{ host }}"
    static_configs:
      - targets: ["{{ hostvars[host]['ansible_host'] }}:{{ node_exporter_port }}"]
        labels:
          node: "{{ host }}"
          chip: "{{ hostvars[host]['node_chip'] }}"
          role: "{{ hostvars[host]['node_role'] | default('unknown') }}"
{% endfor %}
{% endfor %}

  - job_name: "loki"
    static_configs:
      - targets: ["loki:{{ loki_port }}"]
