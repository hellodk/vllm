# ============================================================
# LiteLLM Proxy — Hydra Pilot Configuration
# Generated by Ansible. Do not edit manually.
# Routes to vLLM-MLX on inference nodes (port {{ vllm_port }})
# ============================================================

model_list:
{% for model in litellm_models %}
  - model_name: "{{ model.model_name }}"
    litellm_params:
      model: "openai/{{ model.backend_model }}"
{% for host in groups['inference'] %}
      api_base: "http://{{ hostvars[host]['ansible_host'] }}:{{ vllm_port }}/v1"
{% endfor %}
      stream: true
      max_tokens: {{ model.max_tokens | default(4096) }}
{% if model.temperature is defined %}
      temperature: {{ model.temperature }}
{% endif %}
{% if model.top_p is defined %}
      top_p: {{ model.top_p }}
{% endif %}
    model_info:
      id: "{{ model.model_name }}"
      description: "{{ model.description }}"
{% endfor %}

router_settings:
  routing_strategy: "least-busy"
  num_retries: 1
  timeout: 120
  enable_pre_call_checks: true
{% if litellm_fallbacks | length > 0 %}
  fallbacks:
{% for fb in litellm_fallbacks %}
    - {{ fb.primary }}: ["{{ fb.fallback }}"]
{% endfor %}
{% endif %}

general_settings:
  master_key: "{{ litellm_api_key }}"
  database_url: "sqlite:///{{ hydra_config_dir }}/litellm/litellm.db"
  otel: true
  max_parallel_requests: 24

litellm_settings:
  success_callback: ["prometheus"]
  failure_callback: ["prometheus"]
  service_callback: ["prometheus"]
  count_tokens: true
  log_responses: true
  cache: true
  cache_params:
    type: "local"
    ttl: 300
