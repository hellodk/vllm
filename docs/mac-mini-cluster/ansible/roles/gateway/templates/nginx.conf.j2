events {
    worker_connections 256;
}

http {
    log_format main '$remote_addr - $remote_user [$time_local] '
                    '"$request" $status $body_bytes_sent '
                    'rt=$request_time';

    access_log /var/log/nginx/access.log main;
    error_log /var/log/nginx/error.log warn;

    proxy_read_timeout 300s;
    proxy_connect_timeout 10s;
    proxy_send_timeout 300s;

    server {
        listen 80;
        server_name _;

        location /health {
            return 200 '{"status":"ok"}';
            add_header Content-Type application/json;
        }

        # LiteLLM API
        location /v1/ {
            proxy_pass http://host.docker.internal:{{ litellm_port }}/v1/;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_buffering off;
            chunked_transfer_encoding on;
        }

        location /chat/completions {
            proxy_pass http://host.docker.internal:{{ litellm_port }}/v1/chat/completions;
            proxy_set_header Host $host;
            proxy_buffering off;
            chunked_transfer_encoding on;
        }

        # Grafana
        location /grafana/ {
            proxy_pass http://grafana:{{ grafana_port }}/;
            proxy_set_header Host $host;
            proxy_http_version 1.1;
            proxy_set_header Upgrade $http_upgrade;
            proxy_set_header Connection "upgrade";
        }

        # Prometheus
        location /prometheus/ {
            proxy_pass http://prometheus:{{ prometheus_port }}/;
            proxy_set_header Host $host;
        }
    }
}
