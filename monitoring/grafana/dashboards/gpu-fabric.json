        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "NVLink TX Bytes / s",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "victoria-metrics" },
          "expr": "DCGM_FI_PROF_NVLINK_TX_BYTES{node_id=~\"$node\", gpu=~\"$gpu\"}",
          "legendFormat": "{{node_id}} gpu{{gpu}} tx",
          "refId": "A"
        }
