      "title": "Prefix Cache Hit Rate",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "victoria-metrics" },
          "expr": "sglang:cache_hit_rate{node_id=~\"$node\"}",
          "legendFormat": "{{node_id}}",
          "refId": "A"
