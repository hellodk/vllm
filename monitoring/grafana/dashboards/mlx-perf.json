          "expr": "hydra:llm:ttft_seconds:p95{provider=~\"$provider\", node_id=~\"$node\"}",
          "legendFormat": "{{provider}} {{model}} {{node_id}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
