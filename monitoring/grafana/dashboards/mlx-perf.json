        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "title": "Sidecar inference (pure mlx_lm / exo)",
      "type": "row",
      "panels": []
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "victoria-metrics"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {
