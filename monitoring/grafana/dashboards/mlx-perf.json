  "templating": {
    "list": [
      {
        "current": {},
        "datasource": {
          "type": "prometheus",
          "uid": "victoria-metrics"
        },
        "definition": "label_values(hydra:llm:requests_running, provider)",
        "hide": 0,
        "includeAll": true,
        "label": "Provider",
        "multi": true,
        "name": "provider",
        "options": [],
        "query": {
          "query": "label_values(hydra:llm:requests_running, provider)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "regex": "/mlx.*|exo/",
        "sort": 1,
        "type": "query"
      },
      {
        "current": {},
        "datasource": {
          "type": "prometheus",
          "uid": "victoria-metrics"
        },
