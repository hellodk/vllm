{
  "__inputs": [],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "11.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Network throughput across the Hydra fleet — per-node host RX/TX (hostmetrics system_network_io_bytes_total), switch uplink utilisation (SNMP ifHCInOctets/ifHCOutOctets), MinIO model storage egress (minio_s3_traffic_sent_bytes), and model-pull duration. TODO(SRE-5): add hostmetrics receiver to Mac OTEL agent config (ANS-3) to populate system_network_io_bytes_total on macOS nodes. TODO(SRE-5): add MinIO scrape job to prometheus.yml when MinIO endpoint is reachable.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Host Network — RX / TX",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "victoria-metrics" },
      "description": "Per-node network receive throughput from OTel hostmetrics receiver (system_network_io_bytes_total with direction=receive). macOS nodes require ANS-3 fix to populate this metric.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "bytes/s",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "insertNulls": false,
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [],
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          },
          "unit": "Bps"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 2,
      "options": {
        "legend": {
          "calcs": ["mean", "max", "lastNotNull"],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Host RX Bytes / s by Node",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "victoria-metrics" },
          "expr": "rate(system_network_io_bytes_total{node_id=~\"$node\", direction=\"receive\", device=~\"$device\"}[1m])",
          "legendFormat": "{{node_id}} {{device}} rx",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "victoria-metrics" },
      "description": "Per-node network transmit throughput from OTel hostmetrics receiver.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "bytes/s",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "insertNulls": false,
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [],
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          },
          "unit": "Bps"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 3,
      "options": {
        "legend": {
          "calcs": ["mean", "max", "lastNotNull"],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Host TX Bytes / s by Node",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "victoria-metrics" },
          "expr": "rate(system_network_io_bytes_total{node_id=~\"$node\", direction=\"transmit\", device=~\"$device\"}[1m])",
          "legendFormat": "{{node_id}} {{device}} tx",
          "refId": "A"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 10,
      "title": "Switch Uplink Utilisation",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "victoria-metrics" },
      "description": "Switch uplink ingress/egress throughput from SNMP exporter (ifHCInOctets / ifHCOutOctets). Link saturation on uplinks causes head-of-line blocking for all TCP and RoCE traffic. TODO(SRE-3): deploy snmp_exporter role for switch.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "bytes/s",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "insertNulls": false,
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "normal" },
            "thresholdsStyle": { "mode": "line+area" }
          },
          "mappings": [],
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "transparent", "value": null },
              { "color": "yellow", "value": 2500000000 },
              { "color": "red", "value": 3000000000 }
            ]
          },
          "unit": "Bps"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 10 },
      "id": 11,
      "options": {
        "legend": {
          "calcs": ["mean", "max", "lastNotNull"],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Switch Uplink Throughput (ingress + egress)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "victoria-metrics" },
          "expr": "rate(ifHCInOctets{ifAlias=~\".*uplink.*\", instance=~\"$switch\"}[1m])",
          "legendFormat": "{{instance}} {{ifAlias}} in",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "victoria-metrics" },
          "expr": "rate(ifHCOutOctets{ifAlias=~\".*uplink.*\", instance=~\"$switch\"}[1m])",
          "legendFormat": "{{instance}} {{ifAlias}} out",
          "refId": "B"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 20,
      "title": "MinIO / Model Storage",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "victoria-metrics" },
      "description": "MinIO S3 egress (model weights served to inference nodes). Source: minio_s3_traffic_sent_bytes counter. A spike in egress typically correlates with a model pull or hot-reload. TODO(SRE-5): add MinIO scrape job to prometheus.yml.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "bytes/s",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 20,
            "gradientMode": "none",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "insertNulls": false,
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [],
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          },
          "unit": "Bps"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "id": 21,
      "options": {
        "legend": {
          "calcs": ["mean", "max", "lastNotNull"],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "MinIO Egress (model weights)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "victoria-metrics" },
          "expr": "rate(minio_s3_traffic_sent_bytes[1m])",
          "legendFormat": "minio egress",
          "refId": "A"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "id": 30,
      "title": "Model Pull Duration",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "victoria-metrics" },
      "description": "Model pull duration from MinIO to inference node. Source: model_pull_duration_seconds histogram (expected from ansible model-pull task with prometheus push or a dedicated probe role). Reference: 32B model at 25 Gbps Thunderbolt 5 ≈ 51 s; at 1 Gbps fallback ≈ 1280 s.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "Seconds",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "insertNulls": false,
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "line+area" }
          },
          "mappings": [],
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "transparent", "value": null },
              { "color": "yellow", "value": 120 },
              { "color": "red", "value": 600 }
            ]
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 28 },
      "id": 31,
      "options": {
        "legend": {
          "calcs": ["mean", "max", "lastNotNull"],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Model Pull Duration by Node",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "victoria-metrics" },
          "expr": "histogram_quantile(0.95, sum(rate(model_pull_duration_seconds_bucket{node_id=~\"$node\"}[10m])) by (le, node_id, model))",
          "legendFormat": "{{node_id}} {{model}} p95",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "victoria-metrics" },
          "expr": "histogram_quantile(0.50, sum(rate(model_pull_duration_seconds_bucket{node_id=~\"$node\"}[10m])) by (le, node_id, model))",
          "legendFormat": "{{node_id}} {{model}} p50",
          "refId": "B"
        }
      ]
    }

  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["network", "throughput", "minio", "hydra"],
  "templating": {
    "list": [
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "victoria-metrics" },
        "definition": "label_values(system_network_io_bytes_total, node_id)",
        "hide": 0,
        "includeAll": true,
        "label": "Node",
        "multi": true,
        "name": "node",
        "options": [],
        "query": {
          "query": "label_values(system_network_io_bytes_total, node_id)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "type": "query"
      },
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "victoria-metrics" },
        "definition": "label_values(system_network_io_bytes_total{node_id=~\"$node\"}, device)",
        "hide": 0,
        "includeAll": true,
        "label": "Device",
        "multi": true,
        "name": "device",
        "options": [],
        "query": {
          "query": "label_values(system_network_io_bytes_total{node_id=~\"$node\"}, device)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
