# monitoring/.env
# Hydra monitoring stack — docker-compose environment.
# Secrets in plain text for now (v1). Vault integration in v2.

# ── Grafana ───────────────────────────────────────────────────────────────────
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=hydra-grafana-admin

# ── Victoria Metrics ──────────────────────────────────────────────────────────
VM_RETENTION=90d

# ── Alertmanager ──────────────────────────────────────────────────────────────
ALERTMANAGER_SLACK_WEBHOOK=https://hooks.slack.com/services/PLACEHOLDER
ALERTMANAGER_SLACK_CHANNEL=#hydra-alerts
ALERTMANAGER_SMTP_SMARTHOST=smtp.hydra.local:587
ALERTMANAGER_SMTP_FROM=hydra-alerts@hydra.local
ALERTMANAGER_SMTP_TO=ops@hydra.local
ALERTMANAGER_SMTP_USER=hydra-alerts
ALERTMANAGER_SMTP_PASSWORD=changeme-smtp  # TODO v2: move to vault

# ── Opik ──────────────────────────────────────────────────────────────────────
OPIK_MYSQL_ROOT_PASSWORD=opik-mysql-root
OPIK_MYSQL_PASSWORD=opik-mysql
OPIK_MYSQL_DATABASE=opik
OPIK_MYSQL_USER=opik
OPIK_CLICKHOUSE_PASSWORD=opik-ch
OPIK_REDIS_PASSWORD=opik-redis

# ── OTEL Collector ────────────────────────────────────────────────────────────
OTEL_COLLECTOR_HOST=0.0.0.0
OTEL_GRPC_PORT=4317
OTEL_HTTP_PORT=4318

# LiteLLM master key (used by Opik as judge LLM API key)
LITELLM_MASTER_KEY=sk-hydra-master-changeme
