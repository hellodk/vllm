# Environment variables for OTEL Collector Gateway
# Copy to /etc/otel-collector/gateway.env and customize

# Gateway identification
GATEWAY_ID=otel-gateway-001
ENVIRONMENT=production

# Prometheus remote_write endpoint (Mimir/Cortex/Thanos)
PROMETHEUS_REMOTE_WRITE_ENDPOINT=http://mimir.internal:9090/api/v1/push

# TLS configuration for Prometheus
PROMETHEUS_TLS_INSECURE=true
# PROMETHEUS_TLS_CERT=/etc/otel/certs/client.crt
# PROMETHEUS_TLS_KEY=/etc/otel/certs/client.key
# PROMETHEUS_TLS_CA=/etc/otel/certs/ca.crt

# Multi-tenancy (for Mimir/Cortex)
PROMETHEUS_TENANT_ID=llm-platform

# Resource limits
GOMAXPROCS=8
GOMEMLIMIT=2GiB
