# Environment variables for OTEL Collector Agent
# Copy to /etc/otel-collector/agent.env and customize

# Node identification
HOSTNAME=mac-mini-001
HOST_ID=mac-mini-001.internal
CLUSTER_NAME=llm-mac-cluster-prod
ENVIRONMENT=production

# OTEL Gateway endpoint (Mode A)
OTEL_GATEWAY_ENDPOINT=otel-gateway.internal:4317

# TLS configuration
OTEL_TLS_INSECURE=false
OTEL_TLS_CERT=/etc/otel/certs/client.crt
OTEL_TLS_KEY=/etc/otel/certs/client.key
OTEL_TLS_CA=/etc/otel/certs/ca.crt

# Optional: Authentication token
# OTEL_AUTH_TOKEN=your-auth-token-here

# Resource limits
GOMAXPROCS=2
GOMEMLIMIT=100MiB
