      "pluginVersion": "10.0.0",
      "targets": [
        {
          "expr": "(histogram_quantile(0.95, rate(llm_output_entropy_bucket{model=~\"$model\", provider=~\"$provider\"}[10m])) / 5) * 0.3 + avg(llm_repetition_score{model=~\"$model\", provider=~\"$provider\"}) * 0.3 + (1 - avg(llm_confidence_mean{model=~\"$model\", provider=~\"$provider\"})) * 0.2 + (histogram_quantile(0.95, rate(llm_perplexity_bucket{model=~\"$model\", provider=~\"$provider\"}[10m])) / 100) * 0.2",
