# /etc/systemd/system/fleet-celery-maintenance.service
# Managed by Ansible — do not edit manually.
# Stale-node sweeps, archive old SBOM scans.
[Unit]
Description=Fleet Platform Celery — Maintenance Worker
After=network.target redis.service postgresql.service
Requires=network.target

[Service]
Type=forking
User={{ hydra_salt_kri_user | default('dk') }}
WorkingDirectory={{ hydra_salt_kri_app_dir }}
ExecStart={{ hydra_salt_kri_venv_dir }}/bin/celery \
  -A fleet_platform.workers.celery_app worker \
  --queues=maintenance \
  --concurrency=1 \
  --loglevel=info \
  --logfile={{ fleet_log_dir }}/celery-maintenance.log \
  --pidfile={{ fleet_log_dir }}/celery-maintenance.pid \
  --detach
ExecStop={{ hydra_salt_kri_venv_dir }}/bin/celery \
  -A fleet_platform.workers.celery_app control shutdown
Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal
SyslogIdentifier=fleet-celery-maintenance

[Install]
WantedBy=multi-user.target
