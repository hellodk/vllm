# /etc/hydra/otel-agent.env
# Managed by Ansible (otel-mac-agent role) — do not edit manually.
# Shell-sourceable for debugging: source /etc/hydra/otel-agent.env && otelcol-contrib --config ...
# Re-render: ansible-playbook mac-monitoring.yml --tags configure --limit {{ hydra_node_id }}

# ── Node identity (also used as Salt minion_id join key) ──────────────────────
export NODE_ID="{{ hydra_node_id }}"
export HOST_NAME="{{ hydra_hostname }}"
export CLUSTER="{{ hydra_cluster_name }}"
export ENVIRONMENT="{{ hydra_environment }}"
export CHIP="{{ hydra_chip | default('unknown') }}"
export POOL="{{ hydra_pools | join(',') }}"

# ── Monitoring destinations ───────────────────────────────────────────────────
export VICTORIA_METRICS_URL="{{ hydra_monitoring_victoria }}"
export OTEL_GATEWAY_ENDPOINT="{{ hydra_monitoring_gateway }}"
{% if hydra_monitoring_fleet_otlp %}
export FLEET_PLATFORM_OTLP="{{ hydra_monitoring_fleet_otlp }}"
{% endif %}

# ── Tuning ────────────────────────────────────────────────────────────────────
export COLLECTION_INTERVAL="{{ hydra_monitoring_interval | default('30s') }}"
export GOMAXPROCS=2
export GOMEMLIMIT=100MiB
