# ~/.zprofile — managed by Ansible (jenkins-ios-agent role)
# Re-render: ansible-playbook jenkins-ios-setup.yml --tags zprofile --limit {{ hydra_node_id }}
# Source: pulse/jenkins-k8s/docs/mac-mini-setup.md §10

# ── Homebrew (Apple Silicon) ──────────────────────────────────────────────────
eval "$(/opt/homebrew/bin/brew shellenv)"

# ── Java 21 ───────────────────────────────────────────────────────────────────
export PATH="{{ homebrew_prefix }}/opt/openjdk@21/bin:$PATH"

# ── rbenv (Ruby {{ ruby_version }}) ─────────────────────────────────────────────
export PATH="{{ jenkins_rbenv_root }}/bin:$PATH"
eval "$(rbenv init -)"

# ── nvm (Node {{ node_version }} LTS) ────────────────────────────────────────────
export NVM_DIR="{{ jenkins_nvm_dir }}"
[ -s "$NVM_DIR/nvm.sh" ] && source "$NVM_DIR/nvm.sh"

# ── CocoaPods ─────────────────────────────────────────────────────────────────
export COCOAPODS_DISABLE_STATS=1

# ── Locale (required by CocoaPods unicode normalisation) ─────────────────────
export LANG=en_US.UTF-8
export LC_ALL=en_US.UTF-8
