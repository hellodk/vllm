# /etc/hydra/otel-agent.env — rendered by monitoring-cfg role
# For debugging: source this file then run otelcol-contrib manually
export NODE_ID={{ hydra_node_id }}
export HOSTNAME={{ hydra_hostname }}
export CLUSTER={{ hydra_cluster_name }}
export ENVIRONMENT={{ hydra_environment }}
export OS={{ hydra_os }}
export GPU_PROVIDER={{ hydra_gpu_provider }}
export CHIP={{ hydra_chip | default('unknown') }}
export POOL={{ hydra_pools | join(',') }}
export OTEL_GATEWAY_PRIMARY={{ hydra_otel_gateway_primary }}
export OTEL_GATEWAY_SECONDARY={{ hydra_otel_gateway_secondary | default('') }}
export GOMAXPROCS=2
export GOMEMLIMIT=100MiB
